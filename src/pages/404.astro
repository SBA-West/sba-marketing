---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTAButton from "@/components/CTAButton.astro";
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist.">
  <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-32 text-center">
    <p class="text-6xl font-extrabold text-brand-accent">404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-brand">
      Page not found
    </h1>
    <p class="mt-4 text-slate-600">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="mt-8">
      <CTAButton href="/">Back to home</CTAButton>
    </div>
  </section>
</BaseLayout>
