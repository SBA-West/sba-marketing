---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.astro";
import { SITE } from "@/lib/site";
---

<BaseLayout
  title="Contact"
  description="Get in touch with SBAWest to start your SBA 7(a) loan application."
>
  <section class="mx-auto grid max-w-6xl gap-12 px-4 py-20 lg:grid-cols-2">
    <div>
      <h1 class="text-4xl font-extrabold tracking-tight text-brand">
        Get started
      </h1>
      <p class="mt-4 text-lg text-slate-700">
        Tell us about your business and financing needs. A loan officer will
        reach out to walk you through the next steps.
      </p>
      <dl class="mt-8 space-y-3 text-slate-700">
        <div>
          <dt class="text-sm font-semibold uppercase tracking-wide text-slate-500">
            Email
          </dt>
          <dd>
            <a href={`mailto:${SITE.email}`} class="text-brand hover:underline">
              {SITE.email}
            </a>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-semibold uppercase tracking-wide text-slate-500">
            Phone
          </dt>
          <dd>
            <a
              href={`tel:${SITE.phone.replace(/[^0-9+]/g, "")}`}
              class="text-brand hover:underline"
            >
              {SITE.phone}
            </a>
          </dd>
        </div>
      </dl>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <ContactForm />
    </div>
  </section>
</BaseLayout>
