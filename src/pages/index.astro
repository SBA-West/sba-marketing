---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/HeroSection.astro";
import ValueProp from "@/components/ValueProp.astro";
import CTAButton from "@/components/CTAButton.astro";
---

<BaseLayout>
  <HeroSection />
  <ValueProp />

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-20">
      <h2 class="text-center text-3xl font-bold tracking-tight text-brand">
        How it works
      </h2>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div>
          <span class="text-4xl font-extrabold text-brand-accent">1</span>
          <h3 class="mt-2 text-lg font-semibold text-brand">Apply online</h3>
          <p class="mt-2 text-sm text-slate-600">
            Tell us about your business and how much you need. It takes minutes.
          </p>
        </div>
        <div>
          <span class="text-4xl font-extrabold text-brand-accent">2</span>
          <h3 class="mt-2 text-lg font-semibold text-brand">We underwrite</h3>
          <p class="mt-2 text-sm text-slate-600">
            Our SBA underwriters review your file and request the documents we
            need.
          </p>
        </div>
        <div>
          <span class="text-4xl font-extrabold text-brand-accent">3</span>
          <h3 class="mt-2 text-lg font-semibold text-brand">Get funded</h3>
          <p class="mt-2 text-sm text-slate-600">
            On approval, we guide you through closing and disbursement.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-brand-dark">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-4 py-20 text-center text-white">
      <h2 class="text-3xl font-bold tracking-tight">
        Ready to grow your business?
      </h2>
      <p class="max-w-xl text-slate-200">
        Start your SBA 7(a) application today and get a dedicated loan officer.
      </p>
      <CTAButton href="/contact">Start your application</CTAButton>
    </div>
  </section>
</BaseLayout>
