---
interface Prop {
  title: string;
  body: string;
}

interface Props {
  heading?: string;
  items?: Prop[];
}

const {
  heading = "Why borrowers choose SBAWest",
  items = [
    {
      title: "Loans up to $5M",
      body: "SBA 7(a) financing for working capital, equipment, real estate, refinancing, and business acquisition.",
    },
    {
      title: "Streamlined application",
      body: "A guided online application and document checklist so you always know what comes next.",
    },
    {
      title: "Real underwriters",
      body: "Experienced SBA underwriters review every file — no black-box scoring, no surprises.",
    },
    {
      title: "Dedicated loan officers",
      body: "One point of contact from application through funding, available when you need them.",
    },
  ],
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-20">
  <h2 class="text-center text-3xl font-bold tracking-tight text-brand">
    {heading}
  </h2>
  <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {
      items.map((item) => (
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-brand">{item.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.body}</p>
        </div>
      ))
    }
  </div>
</section>
