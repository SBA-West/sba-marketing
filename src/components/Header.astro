---
import { SITE, NAV } from "@/lib/site";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="text-xl font-extrabold tracking-tight text-brand">
      1West<span class="text-brand-accent">SBA</span>
    </a>

    <nav aria-label="Primary" class="hidden gap-6 md:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={[
              "text-sm font-medium transition-colors hover:text-brand",
              isActive(item.href) ? "text-brand" : "text-slate-600",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="/contact"
      class="hidden rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-light md:inline-block"
    >
      Apply Now
    </a>
  </div>

  <!-- Mobile nav -->
  <nav
    aria-label="Mobile"
    class="flex flex-wrap gap-4 border-t border-slate-100 px-4 py-3 md:hidden"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm font-medium",
            isActive(item.href) ? "text-brand" : "text-slate-600",
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
  <span class="sr-only">{SITE.name}</span>
</header>
