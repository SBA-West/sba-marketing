---
// V1 placeholder: this form has no backend wiring yet.
// Ops follows up on submissions manually until the portal API lead endpoint exists.
// TODO: POST to the lead-intake endpoint once sba-portal-api exposes it.
const labelClass = "block text-sm font-medium text-slate-700";
const inputClass =
  "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand";
---

<form
  name="contact"
  method="post"
  action="#"
  class="space-y-5"
  aria-label="Contact 1West SBA"
>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="firstName" class={labelClass}>First name</label>
      <input id="firstName" name="firstName" type="text" required class={inputClass} />
    </div>
    <div>
      <label for="lastName" class={labelClass}>Last name</label>
      <input id="lastName" name="lastName" type="text" required class={inputClass} />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="email" class={labelClass}>Email</label>
      <input id="email" name="email" type="email" required class={inputClass} />
    </div>
    <div>
      <label for="phone" class={labelClass}>Phone</label>
      <input id="phone" name="phone" type="tel" class={inputClass} />
    </div>
  </div>

  <div>
    <label for="businessName" class={labelClass}>Business name</label>
    <input id="businessName" name="businessName" type="text" class={inputClass} />
  </div>

  <div>
    <label for="loanAmount" class={labelClass}>Requested loan amount (USD)</label>
    <input
      id="loanAmount"
      name="loanAmount"
      type="number"
      min="50000"
      max="5000000"
      step="1000"
      placeholder="250000"
      class={inputClass}
    />
  </div>

  <div>
    <label for="message" class={labelClass}>How can we help?</label>
    <textarea id="message" name="message" rows="4" class={inputClass}></textarea>
  </div>

  <button
    type="submit"
    class="inline-flex items-center justify-center rounded-md bg-brand px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-light focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
  >
    Submit
  </button>
</form>
