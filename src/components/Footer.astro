---
import { SITE, NAV } from "@/lib/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-brand-dark text-slate-300">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:grid-cols-2 md:grid-cols-3">
    <div>
      <span class="text-lg font-extrabold tracking-tight text-white">
        SBA<span class="text-brand-accent">West</span>
      </span>
      <p class="mt-3 max-w-xs text-sm text-slate-400">
        SBA 7(a) financing for small businesses, backed by experienced loan
        officers and a streamlined process.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-white">
        Navigate
      </h2>
      <ul class="mt-3 space-y-2 text-sm">
        {
          NAV.map((item) => (
            <li>
              <a href={item.href} class="hover:text-white">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-white">
        Contact
      </h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a href={`mailto:${SITE.email}`} class="hover:text-white">
            {SITE.email}
          </a>
        </li>
        <li>
          <a href={`tel:${SITE.phone.replace(/[^0-9+]/g, "")}`} class="hover:text-white">
            {SITE.phone}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10 px-4 py-6">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 text-xs text-slate-400 sm:flex-row">
      <p>&copy; {year} {SITE.name}. All rights reserved.</p>
      <p>SBA loans subject to credit approval and SBA eligibility.</p>
    </div>
  </div>
</footer>
